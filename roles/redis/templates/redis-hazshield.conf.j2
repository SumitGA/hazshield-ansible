# HazShield Redis — hot lane (pub/sub + streams). Managed by Ansible.
bind 127.0.0.1 {{ state_ip }}
port 6379
protected-mode yes
requirepass {{ redis_password }}

# --- Debian/Ubuntu integration (required for the stock systemd unit) ---
supervised systemd
dir /var/lib/redis
pidfile /run/redis/redis-server.pid
logfile /var/log/redis/redis-server.log

# The hot lane must NEVER silently evict a violation. If we hit the cap,
# writes fail loudly and the Rust edge spills to its local AOF fallback.
maxmemory {{ redis_maxmemory }}
maxmemory-policy noeviction

# Durability for streams: AOF with per-second fsync. RDB snapshotting off.
appendonly yes
appendfsync everysec
save ""

tcp-keepalive 60
timeout 0
databases 4
loglevel notice
